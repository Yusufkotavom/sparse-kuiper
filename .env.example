# Environment Variables for Nomad Hub

# ── AI APIs ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Database ─────────────────────────────────────────────
# Wajib: PostgreSQL / Supabase pooled connection string
DATABASE_URL=postgresql+psycopg://postgres.xxxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
ENABLE_LEGACY_IMPORTS=0

# ── Frontend Supabase ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_REALTIME_SCHEMA=public

# ── Directories (optional overrides) ─────────────────────
# UPLOAD_QUEUE_DIR=./upload_queue
# SESSIONS_DIR=./data/sessions
# VIDEO_PROJECTS_DIR=./video_projects
# PROJECTS_DIR=./projects

# ── App Settings ──────────────────────────────────────────
# ENVIRONMENT=production
