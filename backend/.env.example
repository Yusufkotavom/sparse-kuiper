# Backend environment template
# Copy this file to backend/.env or project-root .env, then adjust values.

# Core
ENVIRONMENT=development
DATABASE_URL=sqlite:///./app.db

# Optional providers
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Grok2API (required if using /generate-grok2api endpoints)
# Example: http://168.110.210.101:8080 or https://api.grok2api.example (tanpa /v1)
GROK2API_BASE_URL=
GROK2API_API_KEY=

# Optional Telegram notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false
